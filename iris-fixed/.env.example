# IRIS Environmental Intelligence Platform - Configuration

# ===== GEMINI API (REQUIRED FOR ADVANCED AI) =====
# Get your free API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# ===== MAILGUN EMAIL SERVICE =====
# IRIS uses Mailgun for email notifications (alerts, user verification, reports)
# Get credentials from: https://www.mailgun.com/
MAILGUN_API_KEY=your_mailgun_api_key_here
MAILGUN_DOMAIN=your_mailgun_domain.mailgun.org
SENDER_EMAIL=noreply@your_mailgun_domain.mailgun.org

# ===== DATABASE =====
# SQLite database path (auto-created if not exists)
DATABASE_PATH=./database.db

# ===== FLASK CONFIGURATION =====
FLASK_ENV=development
FLASK_DEBUG=False
SECRET_KEY=iris-env-intelligence-2024

# ===== SERVER CONFIGURATION =====
# Server host and port
SERVER_HOST=0.0.0.0
SERVER_PORT=5000

# ===== LOGGING =====
LOG_LEVEL=INFO
